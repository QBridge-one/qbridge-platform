# AI manifest generator — used ONLY by `yarn generate:manifest` (or
# `yarn generate --ai-manifest`). Plain `yarn generate` is deterministic and
# needs no key. See src/contracts/README.md.
ANTHROPIC_API_KEY=sk-ant-...
# Optional: fallback when Anthropic is out of credits / rate-limited (MANIFEST_AI_PROVIDER=auto, default)
GEMINI_API_KEY=
# Primary model (bare names like gemini-1.5-flash often 404 — use listModels or built-in fallbacks)
# GEMINI_MODEL=gemini-flash-latest
# Extra comma-separated models to try before built-in fallbacks
# GEMINI_MODEL_TRY=gemini-1.5-flash-002
# Only GEMINI_MODEL (+ GEMINI_MODEL_TRY), no built-in cascade
# GEMINI_DISABLE_MODEL_FALLBACK=1
# Skip GET /v1beta/models discovery after static list fails
# GEMINI_SKIP_MODEL_DISCOVERY=1
# auto | anthropic | gemini
# MANIFEST_AI_PROVIDER=auto

# Contact form (Zoho SMTP)
ZOHO_SMTP_USER=contact@qbridge.one
ZOHO_SMTP_PASS=your_app_password
ZOHO_SMTP_HOST=smtppro.zohocloud.ca
CONTACT_FORM_TO_EMAIL=your@email.com

# ─── Wallet provider (Privy) ────────────────────────────────
# Privy is the embedded-wallet provider. Clerk remains the only login:
# Privy verifies the Clerk session JWT and provisions an MPC embedded
# wallet bound to the Clerk user. The WalletPort interface is provider-
# agnostic, so adding Alchemy/Turnkey later is a config + adapter change.
#
#   1. Create an app at https://dashboard.privy.io → copy the App ID.
#   2. Dashboard → User management → Authentication → JWT-based auth: add
#      your Clerk JWKS URL (https://<clerk-frontend-api>/.well-known/jwks.json),
#      ID claim = "sub", aud empty.
#   3. Dashboard → User management → Authentication → Advanced: enable
#      "Return user data in an identity token" (so /api/wallet/bind can
#      verify it and resolve the embedded wallet).
NEXT_PUBLIC_WALLET_PROVIDER=privy
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
# App secret — SERVER-ONLY (never NEXT_PUBLIC). Dashboard → Settings → App secret.
PRIVY_APP_SECRET=privy_...
# Chain selection: omit/devnet → Sepolia; "mainnet" → Ethereum L1 + Polygon
# NEXT_PUBLIC_PRIVY_NETWORK=devnet
# Gas sponsorship (off by default). Set true ONLY after enabling, in the Privy
# dashboard: gas sponsorship + chains + "Allow transactions from the client"
# (and TEE execution on wallets). When off, the wallet pays its own gas.
# NEXT_PUBLIC_PRIVY_SPONSOR_GAS=false

# ─── Identity / B2B Workspaces ──────────────────────────────
# Active identity adapter. Options: none | memory | clerk
#   none   : (default if unset) unauthenticated. Visitors land on
#            the marketing page. Use this until you've decided
#            which provider to wire up.
#   memory : in-process dev fixture — auto-signs in as a synthetic
#            "dev_root" user who's admin of pre-seeded "QBridge Ops"
#            and "Demo Issuer" orgs. No IdP keys required.
#   clerk  : Clerk Organizations (requires CLERK_* vars below).
#
# IMPORTANT: "memory" mode auto-authenticates *every* request as
# the fixture user, so don't enable it in shared/preview environments.
# A fresh clone with no .env stays in "none" mode on purpose so
# nobody is silently dropped into /ops as an admin.
IDENTITY_PROVIDER=memory

# Clerk (only used when IDENTITY_PROVIDER=clerk)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# CLERK_WEBHOOK_SECRET=whsec_...      # from Clerk Dashboard → Webhooks
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/select-workspace
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/select-workspace

# ─── Postgres (chain-role indexer + materialized state) ─────
# Used by the Drizzle client (src/lib/db) and the indexer worker
# (src/scripts/indexer.ts).
#
# Neon: pooled host (`*-pooler.*`) recommended. Paste into .env.local (dev).
# See docs/database-and-chain-roles.md for who reads Postgres vs chain, Railway vs Vercel.
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ─── Platform notifications + transactional email ───────────
# In-app notifications (bell, ops queue) and the `kyb.*` email
# fanout. When DATABASE_URL is set, audit + notifications are
# persisted in Postgres; otherwise in-memory adapters are used.
#
# OPS_ORG_ID: Clerk org id of the QBridge ops workspace. Required
# for `issuer.kyb_submitted` notifications to find a recipient set;
# when unset, the issuer submit path still works but ops members
# aren't paged. Find it in Clerk Dashboard → Organizations.
# OPS_ORG_ID=org_xxx
#
# Email provider for transactional sends (NOT the contact form —
# that stays on Zoho SMTP). Options: console | resend
#   console : log sends to stdout (dev / preview, default)
#   resend  : POST to api.resend.com (set RESEND_API_KEY + EMAIL_FROM)
EMAIL_PROVIDER=console
# RESEND_API_KEY=re_...
# EMAIL_FROM must be on a verified Resend sending domain. Recommended:
# put platform mail on a subdomain (e.g. mail.qbridge.one) so its
# SPF/DKIM/DMARC records don't compete with Zoho's records on the
# apex domain, and a deliverability issue on platform mail can't
# poison the contact@ mailbox reputation.
# EMAIL_FROM=QBridge <notifications@mail.qbridge.one>
#
# Email outbox drain: the Railway indexer worker (src/scripts/indexer.ts)
# runs `startEmailOutboxDrainLoop()` alongside the chain watcher and
# drains pending emails every 2 minutes — no extra service needed.
#
# Manual drain endpoint /api/cron/drain-emails is kept for ops use
# (curl, on-demand backfill, future Vercel Pro cron). Protect it with
# CRON_SECRET — when unset the route returns 503.
# CRON_SECRET=generate_a_long_random_string

# ─── KYB verification (Persona) ─────────────────────────────
# Step 2 of issuer onboarding. The Persona inquiry widget is
# embedded in /workspace/onboarding; webhook events fire to
# /api/webhooks/persona. When PERSONA_API_KEY is missing, the
# port throws on first use — issuers can still complete step 1
# (application) without it.
#
# Two providers are wired behind one KybVerificationPort. Routing:
#   KYB_PROVIDER            — global default ("persona" | "sumsub"),
#                             default "persona"
#   KYB_JURISDICTION_PROVIDERS — optional per-jurisdiction overrides.
#                             Keys are ISO 3166-1 alpha-2 codes
#                             (lowercased: "ca", "us", "gb", "ae"...).
#                             Legacy free-text values ("Canada", "USA")
#                             are normalized at lookup, so both forms
#                             work, but new entries should be ISO.
# KYB_PROVIDER=persona
# KYB_JURISDICTION_PROVIDERS=ca:sumsub,us:persona

# Persona — https://app.withpersona.com
# PERSONA_API_KEY=persona_sandbox_...
# PERSONA_TEMPLATE_ID=itmpl_...
# PERSONA_WEBHOOK_SECRET=wbhk_...
# PERSONA_ENVIRONMENT=sandbox

# Sumsub — https://cockpit.sumsub.com (supports Canada KYB)
# Dashboard → Dev Space → App Tokens (token + secret key)
# SUMSUB_APP_TOKEN=sbx:...
# SUMSUB_SECRET_KEY=...
# SUMSUB_WEBHOOK_SECRET=...
# KYB level names — two supported patterns:
#
# A. Single level (simplest — swap value to switch):
# SUMSUB_KYB_LEVEL=full-kyb-level
#
# B. Tiered (both configured, flip a switch to change active default —
#    sets you up for per-case picking later without env changes):
# SUMSUB_KYB_LEVEL_BASIC=basic-kyb-level
# SUMSUB_KYB_LEVEL_FULL=full-kyb-level
# SUMSUB_KYB_LEVEL_TIER=full              # "basic" | "full" (default "full")
#
# Pattern A takes precedence if both are set. Use one or the other.
#
# Individual KYC level (future, role-gated member verification):
# SUMSUB_KYC_LEVEL=qbridge-kyc

# ─── Deployed contracts (Sepolia / mainnet / Polygon) ───────
# Use proxy addresses for upgradeable contracts (e.g. IssuerRegistry).
# NEXT_PUBLIC_PLATFORM_AM_SEPOLIA=0x...
# NEXT_PUBLIC_TOKEN_AM_SEPOLIA=0x...
# NEXT_PUBLIC_ISSUER_REGISTRY_SEPOLIA=0x...
# NEXT_PUBLIC_TOKEN_REGISTRY_SEPOLIA=0x...
# NEXT_PUBLIC_FACTORY_SEPOLIA=0x...
# NEXT_PUBLIC_PLATFORM_AM_MAINNET=0x...
# NEXT_PUBLIC_TOKEN_AM_MAINNET=0x...
# NEXT_PUBLIC_ISSUER_REGISTRY_MAINNET=0x...
# NEXT_PUBLIC_TOKEN_REGISTRY_MAINNET=0x...
# NEXT_PUBLIC_FACTORY_MAINNET=0x...
# NEXT_PUBLIC_PLATFORM_AM_POLYGON=0x...
# NEXT_PUBLIC_TOKEN_AM_POLYGON=0x...
# NEXT_PUBLIC_ISSUER_REGISTRY_POLYGON=0x...
# NEXT_PUBLIC_TOKEN_REGISTRY_POLYGON=0x...
# NEXT_PUBLIC_FACTORY_POLYGON=0x...

# ─── RPC endpoints (optional) ───────────────────────────────
# Override the public RPC used for on-chain reads. Leave unset to use a
# reliable public node (lib/rpc.ts). viem's bare default is rate-limited
# and can make reads return empty — set these for production.
# NEXT_PUBLIC_SEPOLIA_RPC_URL=https://...
# NEXT_PUBLIC_MAINNET_RPC_URL=https://...
# NEXT_PUBLIC_POLYGON_RPC_URL=https://...

# ─── Chain-role indexer ─────────────────────────────────────
# Block to backfill role events from. Use the earliest of your
# deployed AccessManager deploy blocks (Sepolia or other chain).
# Set to a recent block to skip 9M+ empty Sepolia blocks. Easiest
# way to find it: open the AM address on Sepolia Etherscan, copy the
# "Created at block" value, subtract a small buffer (~1000).
# When you redeploy AMs (PR 2), bump this to the new deploy block.
INDEXER_START_BLOCK_SEPOLIA=0
# Optional override of the chunk size used during backfill
# (max range per eth_getLogs call). Public RPCs cap this — Sepolia
# public node accepts ~10k blocks at a time.
# INDEXER_BACKFILL_CHUNK=10000

# Public base URL of the app (NO trailing slash). Used by the
# /api/team/invite route to build the `redirectUrl` Clerk attaches
# to invitation emails so the recipient lands on /select-workspace
# inside the app (and NOT on Clerk's default "Start Building" page).
# Falls back to the request's Origin header if unset, so this is
# strictly required only for non-browser-initiated invites (CI,
# server-to-server). Highly recommended in dev for predictability.
#   Dev:   http://localhost:3000
#   Prod:  https://app.qbridge.one
# NEXT_PUBLIC_APP_URL=http://localhost:3000
