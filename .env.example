# AI manifest generator — used by `yarn generate` (manifest step; see src/contracts/README.md)
ANTHROPIC_API_KEY=sk-ant-...
# Optional: fallback when Anthropic is out of credits / rate-limited (MANIFEST_AI_PROVIDER=auto, default)
GEMINI_API_KEY=
# Primary model (bare names like gemini-1.5-flash often 404 — use listModels or built-in fallbacks)
# GEMINI_MODEL=gemini-flash-latest
# Extra comma-separated models to try before built-in fallbacks
# GEMINI_MODEL_TRY=gemini-1.5-flash-002
# Only GEMINI_MODEL (+ GEMINI_MODEL_TRY), no built-in cascade
# GEMINI_DISABLE_MODEL_FALLBACK=1
# Skip GET /v1beta/models discovery after static list fails
# GEMINI_SKIP_MODEL_DISCOVERY=1
# auto | anthropic | gemini
# MANIFEST_AI_PROVIDER=auto

# Contact form (Zoho SMTP)
ZOHO_SMTP_USER=contact@qbridge.one
ZOHO_SMTP_PASS=your_app_password
ZOHO_SMTP_HOST=smtppro.zohocloud.ca
CONTACT_FORM_TO_EMAIL=your@email.com

# ─── Wallet provider ────────────────────────────────────────
# Selects which embedded-wallet adapter the client + transaction
# service uses. The WalletPort interface is identical across
# providers; swapping is a config change, not a code change.
#
# Options:
#   web3auth  : Web3Auth embedded EOA (default, current)
#   alchemy   : Alchemy Account Kit smart account (stub — fill in
#               src/lib/adapters/wallet/alchemy.adapter.ts)
#   turnkey   : Turnkey HSM-backed signer (not yet implemented)
NEXT_PUBLIC_WALLET_PROVIDER=web3auth

# Web3Auth-specific (used when NEXT_PUBLIC_WALLET_PROVIDER=web3auth)
NEXT_PUBLIC_WEB3AUTH_CLIENT_ID=your_web3auth_client_id
# Optional: use "mainnet" for production (SAPPHIRE_MAINNET), omit for dev (SAPPHIRE_DEVNET)
# NEXT_PUBLIC_WEB3AUTH_NETWORK=devnet

# ─── Identity / B2B Workspaces ──────────────────────────────
# Active identity adapter. Options: none | memory | clerk
#   none   : (default if unset) unauthenticated. Visitors land on
#            the marketing page. Use this until you've decided
#            which provider to wire up.
#   memory : in-process dev fixture — auto-signs in as a synthetic
#            "dev_root" user who's admin of pre-seeded "QBridge Ops"
#            and "Demo Issuer" orgs. No IdP keys required.
#   clerk  : Clerk Organizations (requires CLERK_* vars below).
#
# IMPORTANT: "memory" mode auto-authenticates *every* request as
# the fixture user, so don't enable it in shared/preview environments.
# A fresh clone with no .env stays in "none" mode on purpose so
# nobody is silently dropped into /ops as an admin.
IDENTITY_PROVIDER=memory

# Clerk (only used when IDENTITY_PROVIDER=clerk)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# CLERK_WEBHOOK_SECRET=whsec_...      # from Clerk Dashboard → Webhooks
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/select-workspace
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/select-workspace

# ─── Postgres (chain-role indexer + materialized state) ─────
# Used by the Drizzle client (src/lib/db) and the indexer worker
# (src/scripts/indexer.ts).
#
# Recommended for dev: Neon (https://console.neon.tech) — free tier,
# branch-per-PR, runs on AWS. Sign up, create a project, copy the
# connection string (pooled URL with `-pooler` host is fine) into
# .env.local as DATABASE_URL.
# Prod: same shape — Neon / Supabase / RDS / etc.
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require
#
# Railway (indexer ONLY): `railway.json` builds from `Dockerfile.indexer`
# (Node 22). Next.js stays on Vercel. Duplicate the indexer env vars
# (`DATABASE_URL` + RPC + AccessManager URLs — same `NEXT_PUBLIC_*` keys as in
# `src/scripts/indexer.ts`) under Railway → Service → Variables.

# ─── Chain-role indexer ─────────────────────────────────────
# Block to backfill role events from. Use the earliest of your
# deployed AccessManager deploy blocks (Sepolia or other chain).
# Set to a recent block to skip 9M+ empty Sepolia blocks. Easiest
# way to find it: open the AM address on Sepolia Etherscan, copy the
# "Created at block" value, subtract a small buffer (~1000).
# When you redeploy AMs (PR 2), bump this to the new deploy block.
INDEXER_START_BLOCK_SEPOLIA=0
# Optional override of the chunk size used during backfill
# (max range per eth_getLogs call). Public RPCs cap this — Sepolia
# public node accepts ~10k blocks at a time.
# INDEXER_BACKFILL_CHUNK=10000

# Public base URL of the app (NO trailing slash). Used by the
# /api/team/invite route to build the `redirectUrl` Clerk attaches
# to invitation emails so the recipient lands on /select-workspace
# inside the app (and NOT on Clerk's default "Start Building" page).
# Falls back to the request's Origin header if unset, so this is
# strictly required only for non-browser-initiated invites (CI,
# server-to-server). Highly recommended in dev for predictability.
#   Dev:   http://localhost:3000
#   Prod:  https://app.qbridge.one
# NEXT_PUBLIC_APP_URL=http://localhost:3000
