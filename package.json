    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.3",
    "persona": "^5.8.0",
    "postgres": "^3.4.9",
