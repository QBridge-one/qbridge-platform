    "indexer": "NODE_OPTIONS='--conditions=react-server' tsx src/scripts/indexer.ts",
    "indexer:once": "INDEXER_ONESHOT=1 NODE_OPTIONS='--conditions=react-server' tsx src/scripts/indexer.ts"
  },
