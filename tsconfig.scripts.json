{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": ".scripts-out",
    "noEmit": false,
    "types": ["node"]
  },
  "include": ["src/scripts/**/*.ts"]
}
